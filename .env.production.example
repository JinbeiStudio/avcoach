# Variables d'environnement à définir sur le serveur Infomaniak
# NE PAS committer ce fichier avec les vraies valeurs

# JWT — générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=8h

# Port exposé par Infomaniak (vérifier dans le panel)
PORT=3000

# Email (iCloud SMTP)
SMTP_USER=julien.gabriel@me.com
SMTP_PASS=
CONTACT_TO=julien.gabriel@me.com
